{
  "buildCommand": null,
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/search", "destination": "/search-v2.html" },
    { "source": "/uk-establishments", "destination": "/uk-establishments.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/client", "destination": "/client.html" },
    { "source": "/client/venues/:venue", "destination": "/client-venue.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin/reports", "destination": "/admin-reports-protected.html" },
    { "source": "/admin/markets", "destination": "/admin-markets-protected.html" },
    { "source": "/operator/:venue", "destination": "/client-venue.html" },
    { "source": "/operator-dashboard", "destination": "/operator-dashboard.html" }
  ],
  "redirects": [
    { "source": "/rankings/stratford-on-avon", "destination": "/rankings/stratford-upon-avon", "permanent": false },
    { "source": "/pricing", "destination": "/for-restaurants#pricing", "permanent": true },
    { "source": "/reports", "destination": "/for-restaurants#preview", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/rankings/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/coverage/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/operator-reports/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/assets/operator-dashboards/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/(login|client|admin)(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, max-age=0"
        }
      ]
    }
  ]
}
