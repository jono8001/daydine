{
  "rules": {
    ".read": false,
    ".write": false,

    "daydine": {
      "establishments": {
        ".read": true,
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
      }
    },

    "daydine_saas": {
      "users": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$uid": {
          ".read": "auth != null && (auth.uid == $uid || root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin')",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "clients": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$clientId": {
          ".read": "auth != null && (root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin' || root.child('daydine_saas/users').child(auth.uid).child('clientId').val() == $clientId)",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "venues": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$venueId": {
          ".read": "auth != null && (root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin' || root.child('daydine_saas/users').child(auth.uid).child('venueIds').child($venueId).val() == true)",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "clientVenueAccess": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$accessId": {
          ".read": "auth != null && (root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin' || data.child('clientId').val() == root.child('daydine_saas/users').child(auth.uid).child('clientId').val())",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "operatorDashboards": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$venueId": {
          ".read": "auth != null && (root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin' || root.child('daydine_saas/users').child(auth.uid).child('venueIds').child($venueId).val() == true)",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
          "snapshots": {
            "$month": {
              ".validate": "newData.hasChildren(['venue_slug','venue','market','month','status'])"
            }
          }
        }
      },

      "marketReadiness": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$marketSlug": {
          ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "coverageCertificates": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$certificateId": {
          ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      },

      "pipelineRuns": {
        ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
        "$runId": {
          ".read": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'",
          ".write": "auth != null && root.child('daydine_saas/users').child(auth.uid).child('role').val() == 'admin'"
        }
      }
    }
  }
}
